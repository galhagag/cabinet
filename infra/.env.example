# Cabinet of Experts — environment configuration
# Copy to .env for local prod-parity runs (docker-compose). In Azure, set
# these on the Container App and store the secrets in Azure Key Vault.

# ── Deployment environment ────────────────────────────────────────────────
# dev | staging | production. Anything other than "dev" enforces a
# fail-closed boot guard: entra auth, a non-empty admin allowlist, Key Vault
# secrets, and non-wildcard CORS all become required (see config.py
# validate_for_environment()). Escape hatch for a non-KV secrets provider in
# staging: CABINET_ALLOW_ENV_SECRETS=1.
CABINET_ENV=dev
CABINET_ALLOW_ENV_SECRETS=

# ── Database ──────────────────────────────────────────────────────────────
# Dev default: sqlite+aiosqlite:///./cabinet.db
# Production:  Azure Database for PostgreSQL Flexible Server
CABINET_DATABASE_URL=postgresql+asyncpg://cabinet:cabinet@postgres:5432/cabinet

# ── LLM runtime (Claude on Microsoft Foundry) ─────────────────────────────
# mock     → deterministic scripted agents (no credentials, no network)
# foundry  → AnthropicFoundry client against your Azure AI resource
CABINET_LLM_MODE=mock
CABINET_FOUNDRY_RESOURCE=            # e.g. thetaray-cabinet (Azure AI resource name)
CABINET_FOUNDRY_MODEL=claude-opus-4-8
CABINET_FOUNDRY_AUTH=api_key         # api_key | entra (Entra ID / managed identity)
CABINET_AGENT_MAX_TOKENS=2048

# ── Loop control ──────────────────────────────────────────────────────────
CABINET_CYCLE_LIMIT=6                # max autonomous agent-to-agent turns

# ── Secrets provider ──────────────────────────────────────────────────────
# env            → CABINET_SECRET_* env vars (dev/test)
# azure_keyvault → Azure Key Vault (production)
CABINET_SECRETS_PROVIDER=env
CABINET_KEYVAULT_URL=                # e.g. https://cabinet-kv.vault.azure.net/

# Secret NAMES expected in Key Vault (or as CABINET_SECRET_* env vars in dev):
#   foundry-api-key                 → Azure AI API key for the Foundry resource
#   google-oauth-client-id          → Google OAuth2 application client id
#   google-oauth-client-secret     → Google OAuth2 application client secret
#   token-encryption-key            → Fernet key for OAuth tokens at rest
#   state-signing-key               → HMAC key for OAuth state signing
#   azure-blob-connection-string    → Blob storage connection (blob provider)
#   webpubsub-connection-string     → Azure Web PubSub connection (realtime)
#   postgres-connection-string      → optional alternative to CABINET_DATABASE_URL
# Dev overrides (env provider), e.g.:
# CABINET_SECRET_GOOGLE_OAUTH_CLIENT_ID=...
# CABINET_SECRET_GOOGLE_OAUTH_CLIENT_SECRET=...
# CABINET_SECRET_FOUNDRY_API_KEY=...

# ── Blob storage ──────────────────────────────────────────────────────────
CABINET_BLOB_PROVIDER=local          # local | azure_blob
CABINET_LOCAL_BLOB_ROOT=./.blob
CABINET_BLOB_CONTAINER=cabinet-skills

# ── Real-time fan-out ─────────────────────────────────────────────────────
CABINET_REALTIME_PROVIDER=inprocess  # inprocess | azure_webpubsub
CABINET_WEBPUBSUB_HUB=cabinet

# ── Google OAuth2 ─────────────────────────────────────────────────────────
CABINET_GOOGLE_REDIRECT_URI=http://localhost:8000/api/gdrive/callback

# ── Invites ───────────────────────────────────────────────────────────────
CABINET_INVITE_TTL_HOURS=168

# ── Authorization ─────────────────────────────────────────────────────────
# Comma-separated admin allowlist for /api/admin/* (baseline prompts, global
# skills). Empty = open access (development ONLY) — always set in production.
CABINET_ADMIN_EMAILS=

# ── Authentication ────────────────────────────────────────────────────────
# dev   → trusted X-User-Email header, no verification (dev/test ONLY)
# entra → Microsoft Entra ID access tokens verified against the tenant's
#         JWKS (signature, issuer, audience, expiry) — no shared secret
CABINET_AUTH_MODE=dev
CABINET_ENTRA_TENANT_ID=      # Entra ID directory (tenant) ID
CABINET_ENTRA_CLIENT_ID=      # API app registration's Application ID (token audience)
# Comma-separated CORS origins for the frontend. "*" (dev default) is
# rejected by the boot guard once CABINET_ENV is staging/production.
CABINET_ALLOWED_ORIGINS=*

# ── Frontend build ────────────────────────────────────────────────────────
VITE_API_BASE=http://localhost:8000

# Entra ID sign-in (MSAL) — only read when VITE_AUTH_MODE=entra
VITE_AUTH_MODE=dev
VITE_ENTRA_TENANT_ID=
VITE_ENTRA_CLIENT_ID=         # frontend SPA app registration's Application ID
VITE_ENTRA_API_SCOPE=         # e.g. api://<CABINET_ENTRA_CLIENT_ID>/access_as_user
