# Cabinet of Experts — backend API (FastAPI)
# Target: Azure Container Apps / AKS
FROM python:3.11-slim

WORKDIR /srv/cabinet

COPY backend/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY backend/app ./app

# Non-root runtime user; owns the workdir so it can create local blob
# storage / sqlite db files at runtime.
RUN useradd --create-home cabinet && chown -R cabinet:cabinet /srv/cabinet
USER cabinet

EXPOSE 8000
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
